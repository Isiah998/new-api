# File path: /etc/systemd/system/qing-api.service
# sudo systemctl daemon-reload
# sudo systemctl start qing-api
# sudo systemctl enable qing-api
# sudo systemctl status qing-api
[Unit]
Description=One API Service
After=network.target

[Service]
User=ubuntu  # 注意修改用户名
WorkingDirectory=/path/to/qing-api  # 注意修改路径
ExecStart=/path/to/qing-api/qing-api --port 3000 --log-dir /path/to/qing-api/logs  # 注意修改路径和端口号
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
